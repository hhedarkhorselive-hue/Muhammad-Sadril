rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: content
    // Document ID: hero, personal, initiatives, social, contact
    // Fields:
    //   - profileImage: string (required)
    //   - name: string (required)
    //   - mainImage: string (required)
    //   - secondImage: string (required)
    //   - thirdImage: string (required)
    //   - introText: string (required)
    //   - motherText: string (required)
    //   - text: string (required)
    //   - image1: string (required)
    //   - image2: string (required)
    //   - screenshotUrl: string (required)
    //   - email: string (required)
    //   - phone: string (required)
    //   - address: string (required)
    //
    // Collection: politicalStories
    // Document ID: auto-generated
    // Fields:
    //   - text: string (required)
    //   - img: string (required)
    //   - order: int (required)
    //
    // Collection: dailyLifeImages
    // Document ID: auto-generated
    // Fields:
    //   - url: string (required)
    //   - order: int (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "hhedarkhorselive@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Public content is readable by everyone
    match /content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /politicalStories/{storyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /dailyLifeImages/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
